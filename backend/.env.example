# Copiar este archivo a ".env" (en la misma carpeta) y completar con las
# credenciales reales del PostgreSQL local. "backend/.env" está en
# .gitignore y nunca debe subirse al repositorio.

db_username=postgres
db_password=
db_hostname=localhost
db_port=5432
db_name=ecommerce

# true habilita el eco de SQL de SQLAlchemy en consola (solo desarrollo)
debug=false

# Firma de los JWT de sesión (RS0028/RS0033). Generar uno propio en producción,
# por ejemplo con: python -c "import secrets; print(secrets.token_hex(32))"
jwt_secret_key=dev-secret-key-cambiar-en-produccion
jwt_algorithm=HS256
jwt_expire_minutes=480
